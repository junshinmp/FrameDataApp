<UserControl x:Class="FrameDataApp.Views.MakeMoveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrameDataApp.Views"
             xmlns:vm="clr-namespace:FrameDataApp.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:MakeMoveViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="Make Move"/>

        <!-- NEW: Character Selector -->
        <Grid Grid.Row="1" Margin="0,15,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Select Character" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="1" 
                      Margin="0,5,0,0" 
                      Height="30" 
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding AvailableCharacters}"
                      SelectedItem="{Binding CharacterName}"/>
        </Grid>

        <!-- Move Name -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Move Name" FontWeight="SemiBold"/>
            <TextBox Grid.Row="1" 
                     Margin="0,5,0,0" 
                     Height="30" 
                     VerticalContentAlignment="Center"
                     Text="{Binding MoveName, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Command Input -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Input" FontWeight="SemiBold"/>
            <TextBox Grid.Row="1" 
                     Margin="0,5,0,0" 
                     Height="30" 
                     VerticalContentAlignment="Center"
                     Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Frame Data Expander -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Expander Header="Frame Data Setup" 
                      FontWeight="SemiBold"
                      IsExpanded="False">
                <Border BorderBrush="Gray" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Padding="10" 
                        Margin="0,5,0,0"
                        Background="#FAFAFA">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Startup Frames" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Height="28" Margin="0,0,5,10" VerticalContentAlignment="Center"
                                 Text="{Binding StartUp, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Active Frames" FontSize="12" Margin="5,0,0,2"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Height="28" Margin="5,0,0,10" VerticalContentAlignment="Center"
                                 Text="{Binding Active, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Recovery Frames" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox Grid.Row="3" Grid.Column="0" Height="28" Margin="0,0,5,0" VerticalContentAlignment="Center"
                                 Text="{Binding Recovery, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="2" Grid.Column="1" Text="On Block Advantage" FontSize="12" Margin="5,0,0,2"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Height="28" Margin="5,0,0,0" VerticalContentAlignment="Center"
                                 Text="{Binding OnBlock, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
            </Expander>
        </Grid>

        <!-- Cancel Options -->
        <Grid Grid.Row="5" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Cancel Options" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="1" 
                      Margin="0,5,0,0" 
                      Height="30" 
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding CancelOptions}"
                      SelectedItem="{Binding SelectedCancelType}"/>
        </Grid>

        <!-- Submit Button -->
        <StackPanel Grid.Row="6"
                    Margin="0,10,0,0"
                    Orientation="Horizontal">
            <Button Content="Save Move" Command="{Binding SaveMoveCommand}" Width="120" Height="32"/>
        </StackPanel>
    </Grid>
</UserControl>