<Window x:Class="FrameDataApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:FrameDataApp.ViewModel"
        xmlns:makeViewModel="clr-namespace:FrameDataApp.ViewModel.MakeViewModels"
        xmlns:views="clr-namespace:FrameDataApp.Views"
        xmlns:makeViews="clr-namespace:FrameDataApp.Views.MakeViews"
        mc:Ignorable="d"
        Title="Frame Data Hub" Height="650" Width="900"
        Background="#0F0F12">

    <DockPanel Background="#0F0F12">
        <!-- 1. Permanent Top Navigation Header -->
        <views:NavBarView DockPanel.Dock="Top" DataContext="{Binding NavBarViewModel}" />

        <!-- 2. Dynamic Main Screen Content -->
        <Grid>
            <!-- Removed Margin="20" so the dark theme touches edge-to-edge -->
            <ContentControl Content="{Binding CurrentViewModel}">
                <ContentControl.Resources>
                    <!-- Home / Dashboard View -->
                    <DataTemplate DataType="{x:Type viewmodel:HomeViewModel}">
                        <views:HomeView />
                    </DataTemplate>

                    <!-- Add Form Views -->
                    <DataTemplate DataType="{x:Type makeViewModel:MakeCharacterViewModel}">
                        <makeViews:MakeCharacterView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type makeViewModel:MakeGameViewModel}">
                        <makeViews:MakeGameView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type makeViewModel:MakeMoveViewModel}">
                        <makeViews:MakeMoveView />
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </DockPanel>
</Window>