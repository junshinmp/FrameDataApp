<UserControl x:Class="FrameDataApp.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="#F4F4F9" 
            BorderBrush="#CCCCCC" 
            BorderThickness="1" 
            CornerRadius="8" 
            Padding="30">

        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Width="300">

            <!-- App Title / Status Indicator -->
            <TextBlock Text="Frame Data Hub" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <TextBlock Text="HomeView successfully loaded in MainWindow!" 
                       FontSize="13" 
                       Foreground="#27AE60" 
                       HorizontalAlignment="Center" 
                       TextWrapping="Wrap"
                       Margin="0,0,0,25"/>

            <Separator Margin="0,0,0,20"/>

            <!-- Navigation Tester Buttons -->
            <TextBlock Text="Quick Actions" 
                       FontSize="14" 
                       FontWeight="SemiBold" 
                       Foreground="#7F8C8D" 
                       Margin="0,0,0,10"/>

            <Button Content="Add New Game" 
                    Command="{Binding NavigateMakeGameCommand}" 
                    Height="38" 
                    Margin="0,0,0,8" 
                    Background="#3498DB" 
                    Foreground="White" 
                    FontWeight="Bold"/>

            <Button Content="Add New Character" 
                    Command="{Binding NavigateMakeCharacterCommand}" 
                    Height="38" 
                    Margin="0,0,0,8"/>

            <Button Content="Add New Move" 
                    Command="{Binding NavigateMakeMoveCommand}" 
                    Height="38"/>

        </StackPanel>
    </Border>
</UserControl>