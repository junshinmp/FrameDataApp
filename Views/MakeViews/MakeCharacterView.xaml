<UserControl x:Class="FrameDataApp.Views.MakeViews.MakeCharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrameDataApp.Views"
             xmlns:vm="clr-namespace:FrameDataApp.ViewModel.MakeViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Modern Dark TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#18181C"/>
            <Setter Property="Foreground" Value="#EEEEF2"/>
            <Setter Property="BorderBrush" Value="#2A2A32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4F4F5E"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F46E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary / Cancel Button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#18181C"/>
            <Setter Property="Foreground" Value="#9898A6"/>
            <Setter Property="BorderBrush" Value="#2A2A32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#25252E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0F0F12">
        <Border Background="#1E1E24" 
                BorderBrush="#2A2A32" 
                BorderThickness="1" 
                CornerRadius="12" 
                Padding="30"
                MaxWidth="600"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,30,0,0">

            <StackPanel>
                <!-- Form Header -->
                <TextBlock Text="CREATE CHARACTER" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#EEEEF2"/>
                <TextBlock Text="Add a new playable character and movement stats" 
                           FontSize="12" 
                           Foreground="#71717A" 
                           Margin="0,4,0,24"/>

                <!-- Character Name -->
                <TextBlock Text="Character Name" Foreground="#A1A1AA" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <!-- Speed Stats Grid -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Walk Speed" Foreground="#A1A1AA" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding WalkSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Dash Speed" Foreground="#A1A1AA" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding DashSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Command="{Binding NavigateHomeCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="110" Margin="0,0,10,0"/>
                    <Button Content="Save Character" Command="{Binding SubmitCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="130"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>